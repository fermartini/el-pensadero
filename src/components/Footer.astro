---
const { lang = 'es' } = Astro.props;

const content = {
  es: {
    disclaimer: "Este es un sitio web de fans no oficial. El universo de Harry Potter y todos sus elementos son propiedad de J.K. Rowling y Warner Bros. Entertainment Inc. No existe afiliación oficial.",
    privacy: "Política de Privacidad",
    terms: "Términos y Condiciones",
    cookies: "Política de Cookies",
    rights: "Todos los derechos reservados."
  },
  en: {
    disclaimer: "This is an unofficial fan website. The Harry Potter universe and all its elements are property of J.K. Rowling and Warner Bros. Entertainment Inc. There is no official affiliation.",
    privacy: "Privacy Policy",
    terms: "Terms and Conditions",
    cookies: "Cookie Policy",
    rights: "All rights reserved."
  }
};

const t = content[lang] || content.es;
---

<footer class="bg-black/90 py-16 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col items-center">
      <h2 class="font-cinzel text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-8">
        El Pensadero
      </h2>
      
      <div class="flex justify-center items-center space-x-10 mb-10">
        <!-- YouTube -->
        <a href="https://www.youtube.com/@elpensadero_HP?sub_confirmation=1" target="_blank" aria-label="YouTube" class="group relative">
          <div class="absolute -inset-2 bg-red-600/20 rounded-full blur-lg opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <svg xmlns="https://www.w3.org/2000/svg" class="relative w-10 h-10 fill-gray-400 group-hover:fill-[#FF0000] transition-all duration-300" viewBox="0 0 24 24">
            <path d="M19.615 3.184C21.063 3.6 22.1 4.637 22.516 6.085 23.27 8.743 23.27 12 23.27 12s0 3.257-.754 5.915c-.416 1.448-1.453 2.485-2.901 2.901C17.958 21.57 12 21.57 12 21.57s-5.958 0-8.615-.754C1.937 20.7.9 19.663.484 18.215-.27 15.557-.27 12-.27 12s0-3.257.754-5.915C1.2 4.637 2.237 3.6 3.685 3.184 6.342 2.43 12 2.43 12 2.43s5.958 0 7.615.754zM9.545 15.568l6.182-3.568-6.182-3.568v7.136z"></path>
          </svg>
        </a>

        <!-- TikTok -->
        <a href="https://www.tiktok.com/@elpensadero_hp" target="_blank" aria-label="TikTok" class="group relative">
          <div class="absolute -inset-2 bg-cyan-400/20 rounded-full blur-lg opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <svg xmlns="https://www.w3.org/2000/svg" class="relative w-10 h-10 fill-gray-400 group-hover:fill-white transition-all duration-300" viewBox="0 0 24 24">
            <path d="M16 8.438c1.093.752 2.38 1.248 3.75 1.36v2.482c-1.708-.072-3.283-.59-4.615-1.458v5.738a6.75 6.75 0 1 1-6.75-6.75 6.667 6.667 0 0 1 1.5.175v2.617a3.938 3.938 0 0 0-1.5-.293 4.125 4.125 0 1 0 4.125 4.125V2.25H16v6.188z"></path>
          </svg>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/elpensadero_hp/" target="_blank" aria-label="Instagram" class="group relative">
          <div class="absolute -inset-2 bg-purple-600/20 rounded-full blur-lg opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <svg xmlns="https://www.w3.org/2000/svg" class="relative w-10 h-10 fill-gray-400 group-hover:fill-[#C13584] transition-all duration-300" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.056 1.97.246 2.43.415a4.92 4.92 0 0 1 1.757 1.01 4.92 4.92 0 0 1 1.01 1.757c.169.46.359 1.26.415 2.43.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.056 1.17-.246 1.97-.415 2.43a4.92 4.92 0 0 1-1.01 1.757 4.92 4.92 0 0 1-1.757 1.01c-.46.169-1.26.359-2.43.415-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.17-.056-1.97-.246-2.43-.415a4.92 4.92 0 0 1-1.757-1.01 4.92 4.92 0 0 1-1.01-1.757c-.169-.46-.359-1.26-.415-2.43C2.175 15.747 2.163 15.367 2.163 12s.012-3.584.07-4.85c.056-1.17.246-1.97.415-2.43a4.92 4.92 0 0 1 1.01-1.757 4.92 4.92 0 0 1 1.757-1.01c.46-.169 1.26-.359 2.43-.415C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.736 0 8.332.012 7.052.07 5.771.129 4.768.319 3.936.608a7.068 7.068 0 0 0-2.55 1.664A7.068 7.068 0 0 0 .608 4.823c-.289.832-.479 1.835-.538 3.116C.012 8.333 0 8.736 0 12c0 3.264.012 3.668.07 4.948.059 1.281.249 2.284.538 3.116a7.068 7.068 0 0 0 1.664 2.55 7.068 7.068 0 0 0 2.55 1.664c.832.289 1.835.479 3.116.538C8.332 23.988 8.736 24 12 24s3.668-.012 4.948-.07c1.281-.059 2.284-.249 3.116-.538a7.068 7.068 0 0 0 2.55-1.664 7.068 7.068 0 0 0 1.664-2.55c.289-.832.479-1.835.538-3.116.058-1.28.07-1.684.07-4.948s-.012-3.668-.07-4.948c-.059-1.281-.249-2.284-.538-3.116a7.068 7.068 0 0 0-1.664-2.55A7.068 7.068 0 0 0 20.063.608c-.832-.289-1.835-.479-3.116-.538C15.668.012 15.264 0 12 0zM12 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a3.999 3.999 0 1 1 0-7.998 3.999 3.999 0 0 1 0 7.998zm6.406-11.845a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"></path>
          </svg>
        </a>
      </div>

      <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-8 text-xs font-cinzel tracking-widest text-gray-500 uppercase">
        <a href={`/${lang}/privacy`} class="hover:text-[#B39D4E] transition-colors">{t.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[#B39D4E] transition-colors">{t.terms}</a>
        <a href={`/${lang}/cookies`} class="hover:text-[#B39D4E] transition-colors">{t.cookies}</a>
      </div>

      <div class="max-w-2xl mx-auto border-t border-white/5 pt-8">
        <p class="text-gray-600 text-[10px] font-spectral italic leading-relaxed mb-4">
          {t.disclaimer}
        </p>
        <p class="text-gray-500 text-[10px] font-cinzel tracking-widest uppercase">
          © {new Date().getFullYear()} El Pensadero. {t.rights}
        </p>
      </div>
    </div>
  </div>
</footer>
