---
const { 
  gamePromoTitle, 
  gamePromoDesc, 
  ytPromoTitle, 
  ytPromoDesc, 
  downloadBtn, 
  visitYtBtn 
} = Astro.props;
---

<section class="w-full max-w-7xl mx-auto px-4 py-24 space-y-32 relative z-10">
  <!-- Game Promotion -->
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
    <div class="w-full lg:w-1/2 group relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-[#B39D4E]/20 to-transparent blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      <img 
        src="/assets/img/icons/game_details_banner_v2.png" 
        alt="Academia Mágica Game" 
        class="relative rounded-3xl shadow-2xl border border-[#B39D4E]/20 w-full object-cover aspect-video transform transition-transform duration-700 group-hover:scale-[1.02]"
      />
    </div>
    
    <div class="w-full lg:w-1/2 space-y-6 text-left">
      <h2 class="text-4xl md:text-5xl font-cinzel font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#FFF8D6] to-[#B39D4E] drop-shadow-sm">
        {gamePromoTitle}
      </h2>
      <div class="space-y-4">
        {gamePromoDesc.split('\n\n').map((para) => (
          <p class="text-gray-300 font-spectral text-lg leading-relaxed italic">
            {para}
          </p>
        ))}
      </div>
      <div class="pt-6">
        <a 
          href="https://play.google.com/store/apps/details?id=com.khalldragon.elpensadero" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-[#B39D4E] to-[#8a763a] text-black font-cinzel font-bold rounded-full transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(218,165,32,0.4)] group"
        >
          {downloadBtn}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- YouTube Promotion -->
  <div class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-20">
    <div class="w-full lg:w-1/2 group relative">
      <div class="absolute -inset-4 bg-gradient-to-l from-red-600/20 to-transparent blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      <img 
        src="/assets/img/icons/youtube_details_banner.png" 
        alt="Canal El Pensadero" 
        class="relative rounded-3xl shadow-2xl border border-red-600/20 w-full object-cover aspect-video transform transition-transform duration-700 group-hover:scale-[1.02]"
      />
    </div>
    
    <div class="w-full lg:w-1/2 space-y-6 text-left lg:text-right">
      <h2 class="text-4xl md:text-5xl font-cinzel font-bold text-transparent bg-clip-text bg-gradient-to-l from-white to-red-600 drop-shadow-sm">
        {ytPromoTitle}
      </h2>
      <p class="text-gray-300 font-spectral text-lg leading-relaxed italic">
        {ytPromoDesc}
      </p>
      <div class="pt-6">
        <a 
          href="https://www.youtube.com/@elpensadero_HP" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-red-700 to-red-900 text-white font-cinzel font-bold rounded-full transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(185,28,28,0.4)] group"
        >
          {visitYtBtn}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
