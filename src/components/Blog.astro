---
import { getCollection } from "astro:content";
import Button from "./Button.astro";
import type { BlogProps } from "../types.d.ts";
import type { string } from "astro:schema";
export interface Props extends BlogProps {}

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}
const { blog, lang, titleButton, readMore } = Astro.props as { blog: string; lang: string; titleButton: string; readMore: string; };

const posts = await getCollection("posts", ({ data }) => data.lang === lang);

// Mezcla aleatoriamente los posts
const shuffledPosts = posts.toSorted(() => 0.5 - Math.random());

const limitedPosts = shuffledPosts.slice(0, 3);

type Post = {
  data: {
    title: string;
    img: string;
    description: string;
    slug: string;
  };
};


---

<section aria-labelledby="noticias-title" id="blog" class="relative py-20 px-4">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(146,137,82,0.1),transparent_50%)]"></div>
  
  <h2
    class="text-3xl md:text-6xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-16 relative z-10 drop-shadow-[0_0_15px_rgba(218,165,32,0.3)]"
    id="noticias-title"
  >
    {blog}
  </h2>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 relative z-10">
    {
      limitedPosts.map((post: Post, index) => {
        const { data } = post;
        const { title, img, description, slug } = data;
        return (
          <article class="group relative flex flex-col h-full bg-slate-900/40 backdrop-blur-md rounded-3xl border border-white/5 hover:border-[#B39D4E]/40 transition-all duration-500 overflow-hidden shadow-2xl hover:shadow-[#B39D4E]/10" style={`animation-delay: ${index * 0.1}s`}>
            <a href={`/${lang}/blog/${slug}`} class="relative block overflow-hidden aspect-video group bg-slate-950">
              {/* Blurred Background to fill space */}
              <img
                class="absolute inset-0 w-full h-full object-cover blur-2xl opacity-40 scale-110"
                src={img}
                alt=""
                aria-hidden="true"
              />
              {/* Main Image */}
              <img
                class="relative w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
                src={img}
                alt={title}
                transition:name={`img-${slug}`}
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-40"></div>
            </a>

            <div class="p-8 flex flex-col flex-grow space-y-4">
              <a href={`/${lang}/blog/${slug}`}>
                <h3 class="text-xl md:text-2xl font-cinzel font-bold text-white group-hover:text-[#B39D4E] transition-colors duration-300 leading-tight">
                  {title}
                </h3>
              </a>
              
              <p class="text-gray-400 font-spectral text-base md:text-lg line-clamp-3 leading-relaxed flex-grow">
                {description}
              </p>

              <div class="pt-4 mt-auto border-t border-white/5">
                <a
                  href={`/${lang}/blog/${slug}`}
                  class="group/btn relative inline-flex items-center gap-2 text-[#B39D4E] font-cinzel text-sm uppercase tracking-widest hover:text-white transition-colors"
                  aria-label={`Leer más sobre: ${title}`}
                >
                  <span class="relative z-10">{readMore}</span>
                  <svg
                    class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>

  <div class="mt-16 flex justify-center relative z-10">
    <Button title=`🪄 ${titleButton}` slug=`/${lang}/blog` aria={lang == "es"? "Ir al blog" : "Go To Blog"}/>
  </div>
</section>
