---
import esFlag from "../assets/flags/es.svg?url";
import usFlag from "../assets/flags/us.svg?url";
const { lang = "es", slugLang = "" } = Astro.props;

const games = lang == "es" ? "juegos" : "Games";

// --- LÓGICA MEJORADA PARA SABER QUÉ PÁGINA ESTÁ ACTIVA ---
const pathname = Astro.url.pathname;
const isHome = pathname === `/${lang}` || pathname === `/${lang}/` || pathname === `/`;
const isBlog = pathname.startsWith(`/${lang}/blog`);
const isGames = pathname.startsWith(`/${lang}/games`);
const isLinks = pathname.startsWith(`/${lang}/links`);

// --- Lógica para el link de cambio de idioma ---
// Usamos 'section' para saber si estamos en 'blog' o 'games'
const [_, _lang, section] = pathname.split("/");
const currentSection = section != undefined ? `/${section}` : "";
const langSwitchUrl = lang == "en" 
  ? `/es${currentSection}/${slugLang}` 
  : `/en${currentSection}/${slugLang}`;
---

<nav
  class="fixed w-full z-50 top-0 start-0 border-b border-gray-900 dark:border-gray-800"
>
  <div
    class="max-w-screen-xl flex flex-wrap justify-between xl:items-center xl:justify-center mx-auto p-4 backdrop-blur-sm"
  >
    <div class="items-center justify-center flex w-full">
      <ul
        class="flex items-center justify-center rounded-lg gap-3 sm:gap-6 md:gap-10 xl:gap-32 font-bold text-xs sm:text-sm md:text-base w-full px-2"
      >
        <li>
          <a
            href={`/${lang}`}
            class={`block py-2 transition-all ${isHome ? 'text-white scale-110 drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] border-b border-[#928952]' : 'text-gray-300 hover:text-[#928952] hover:scale-110'}`}
            aria-current={isHome ? "page" : false}
          >
            Home
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/blog`}
            class={`block py-2 transition-all ${isBlog ? 'text-white scale-110 drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] border-b border-[#928952]' : 'text-gray-300 hover:text-[#928952] hover:scale-110'}`}
            aria-current={isBlog ? "page" : false}
          >
            Blog
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/games`}
            class={`block py-2 transition-all ${isGames ? 'text-white scale-110 drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] border-b border-[#928952]' : 'text-gray-300 hover:text-[#928952] hover:scale-110'}`}
            aria-current={isGames ? "page" : false}
          >
            {games}
          </a>
        </li>
        <li>
          <a
            href={`/${lang}/links`}
            class={`block py-2 font-bold transition-all text-center leading-tight text-[#DAA520] ${isLinks ? 'scale-110 drop-shadow-[0_0_12px_rgba(218,165,32,0.8)] border-b border-[#DAA520]' : 'hover:text-white hover:scale-110'}`}
            aria-current={isLinks ? "page" : false}
          >
            <span class="hidden sm:inline">{lang === 'es' ? 'Academia Mágica' : 'Magic Academy'}</span>
            <span class="sm:hidden">{lang === 'es' ? 'App' : 'App'}</span>
          </a>
        </li>
        <div class="flex justify-end w-fit align-middle">
          <a
            href={langSwitchUrl}
            class="flex gap-1 cursor-pointer w-fit h-fit items-center ml-1 sm:ml-4"
            aria-label={lang == 'es' ? 'Change to English' : 'Cambiar a Español'}
          >
            <img
              src={esFlag}
              alt="Bandera España"
              width={lang == "es" ? 32 : 16}
              height={lang == "es" ? 22 : 11}
              class={`md:w-[${lang == "es" ? '40px' : '20px'}] md:h-[${lang == "es" ? '28px' : '14px'}] transition-all h-auto`}
            />
            <span class="text-gray-400 text-xs sm:text-base mx-1">|</span>
            <img
              src={usFlag}
              alt="Bandera EEUU"
              width={lang == "en" ? 32 : 16}
              height={lang == "en" ? 22 : 11}
              class={`md:w-[${lang == "en" ? '40px' : '20px'}] md:h-[${lang == "en" ? '28px' : '14px'}] transition-all h-auto`}
            />
          </a>
        </div>
      </ul>
    </div>
  </div>
</nav>
