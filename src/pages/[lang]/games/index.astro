---
import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../components/Footer.astro";
import HogwartsSortingQuiz from "../../../components/games/HogwartsSortingQuiz";
import PatronusGame from "../../../components/games/PatronusGame.jsx";
import RoscoGame from "../../../components/games/RoscoGame.jsx";
import type { GamesContent } from "../../../types.d.ts";
export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: "es" } }, // Español
    { params: { lang: "en" } }, // Inglés
  ];
}

import { getImage } from "astro:assets";
import roscoCover from "../../../assets/img/icons/rosco-cover.webp";
import bgForest from "../../../assets/game/bg-forest.webp";
import dementorBody from "../../../assets/game/dementor-body.webp";
import dementorAuraLeft from "../../../assets/game/dementor-aura-left.webp";
import dementorAuraRight from "../../../assets/game/dementor-aura-right.webp";
import harryIdle from "../../../assets/game/harry-idle.webp";
import harryDead from "../../../assets/game/harry-dead.webp";
import patronusBlast from "../../../assets/game/patronus-blast.webp";

// Optimize images for games
const optimizedRoscoCover = await getImage({ src: roscoCover, width: 400, format: 'webp' });
const optimizedBgForest = await getImage({ src: bgForest, width: 1200, format: 'webp' });
const optDementorBody = await getImage({ src: dementorBody, width: 200, format: 'webp' });
const optDementorLeft = await getImage({ src: dementorAuraLeft, width: 300, format: 'webp' });
const optDementorRight = await getImage({ src: dementorAuraRight, width: 300, format: 'webp' });
const optHarryIdle = await getImage({ src: harryIdle, width: 200, format: 'webp' });
const optHarryDead = await getImage({ src: harryDead, width: 200, format: 'webp' });
const optPatronusBlast = await getImage({ src: patronusBlast, width: 200, format: 'webp' });

const { lang } = Astro.params;
const langDif = lang == 'es'? 'en' : 'es'
// 3. Carga el contenido correspondiente
const { frontmatter } = (await import(`../../../content/${lang}/games.md`)) as {
  frontmatter: GamesContent;
};

const title = frontmatter.title;
const titleLayout = frontmatter.titleLayout;
const descriptionLayout = frontmatter.descriptionLayout;
const titleGame = frontmatter.titleGame;
const descriptionGame = frontmatter.descriptionGame;
const hat = frontmatter.hat;
const start = frontmatter.start;
const cualities = frontmatter.cualities;
const fundador = frontmatter.fundador;
const element = frontmatter.element;
const yes = frontmatter.yes;
const thinks = frontmatter.thinks;
const again = frontmatter.again;
const back = frontmatter.back;
const ask = frontmatter.ask;
const of = frontmatter.of;
const interesting = frontmatter.interesting;
const finishGame = frontmatter.finishGame;
---

<Layout
  title={titleLayout}
  description={descriptionLayout}
  url={`/${lang}/games`}
  background={false}
  canonical={`https://elpensaderohp.com/${lang}/games/`}
  alternate={`https://elpensaderohp.com/${langDif}/games/`}
  ><main class="min-h-screen pb-20">
    <h1
      class="opacity-0 animate-fadeIn font-cinzel font-semibold text-2xl md:text-5xl mt-20 mb-10 text-center text-[#B39D4E] drop-shadow-[0_2px_10px_rgba(0,0,0,0.4)] max-w-4xl mx-auto px-4"
    >
      {title}
    </h1>
    
    <div class="mb-20 max-w-7xl mx-auto px-4">
      <h2 class="text-3xl md:text-5xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-slate-200 to-slate-500 mb-12 drop-shadow-[0_0_15px_rgba(200,200,200,0.3)] max-w-4xl mx-auto">
        {lang === 'en' ? 'The Wizarding Rosco: A-Z Challenge' : 'El Rosco Mágico: Desafío de la A a la Z'}
      </h2>
      <RoscoGame client:load lang={lang} coverImg={optimizedRoscoCover.src} />
    </div>

    <div class="border-t border-white/10 pt-20 mb-20 max-w-7xl mx-auto px-4">
      <h2 class="text-3xl md:text-5xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-slate-200 to-slate-500 mb-6 drop-shadow-[0_0_15px_rgba(200,200,200,0.3)] max-w-4xl mx-auto">
        {lang === 'en' ? 'Expecto Patronum: Dementor Defense' : 'Expecto Patronum: Defensa contra Dementores'}
      </h2>
      <PatronusGame 
        client:visible 
        bgImg={optimizedBgForest.src}
        dementorBodyImg={optDementorBody.src}
        dementorAuraLeftImg={optDementorLeft.src}
        dementorAuraRightImg={optDementorRight.src}
        harryIdleImg={optHarryIdle.src}
        harryDeadImg={optHarryDead.src}
        patronusBlastImg={optPatronusBlast.src}
      />
    </div>

    <div class="border-t border-white/10 pt-20 mb-10">
      <HogwartsSortingQuiz
        client:visible
        lang={lang}
        titleGame={titleGame}
        descriptionGame={descriptionGame}
        hat={hat}
        start={start}
        finishGame={finishGame}
        cualities={cualities}
        fundador={fundador}
        element={element}
        yes={yes}
        thinks={thinks}
        again={again}
        back={back}
        ask={ask}
        of={of}
        interesting={interesting}
      />
    </div>
    <Footer />
  </main>
</Layout>
