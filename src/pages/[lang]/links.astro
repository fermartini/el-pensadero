---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params;
const langDif = lang == 'es' ? 'en' : 'es';

const title = lang === 'es' ? 'Nuestras Redes' : 'Our Links';
const description = lang === 'es' ? 'Encuentra todos los enlaces a Academia Mágica y nuestras redes sociales.' : 'Find all links to Academia Mágica and our social media.';
---

<Layout
  title={title}
  description={description}
  url={`/${lang}/links`}
  background={true}
  canonical={`https://elpensaderohp.com/${lang}/links/`}
  alternate={`https://elpensaderohp.com/${langDif}/links/`}
>
  <main class="min-h-screen pb-20 pt-32 px-4 flex flex-col items-center">
    
    <!-- Profile / Game Header -->
    <div class="max-w-xl w-full mx-auto flex flex-col items-center text-center animate-fadeIn mb-8">
      <h1 class="text-5xl md:text-6xl font-cinzel font-bold text-[#DAA520] drop-shadow-[0_2px_15px_rgba(218,165,32,0.5)]">
        EL PENSADERO
      </h1>
    </div>

    <!-- Main Buttons -->
    <div class="max-w-xl w-full mx-auto mt-8 flex flex-col gap-6 relative z-10 animate-fadeInScale" style="animation-delay: 0.2s;">
      
      <!-- GAME LINK - ACADEMIA MAGICA -->
      <a 
        href="https://play.google.com/store/apps/details?id=com.khalldragon.elpensadero" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative flex flex-col items-center justify-center p-[2px] rounded-2xl overflow-hidden hover:scale-105 transition-transform duration-300 shadow-[0_0_25px_rgba(218,165,32,0.3)] bg-gradient-to-b from-[#DAA520] to-[#59430c]"
      >
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#DAA520]/40 to-transparent group-hover:translate-x-full transition-transform duration-1000 -translate-x-full z-10"></div>
        <div class="w-full bg-slate-900 rounded-2xl p-4 flex flex-col items-center text-center relative z-20 gap-3 border border-[#DAA520]/20 overflow-hidden">
          <div class="absolute inset-0 bg-[url('/assets/buttons/name.webp')] bg-contain bg-center bg-no-repeat opacity-20 group-hover:opacity-40 transition-opacity z-0"></div>
          <h3 class="text-2xl font-cinzel font-bold text-[#DAA520] drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)] relative z-10">
            {lang === 'es' ? '¡Descarga el Juego Aquí!' : 'Download the Game Here!'}
          </h3>
          <div class="flex gap-2 justify-center max-w-full relative z-10">
            <img src="/assets/buttons/home.webp" alt="Home preview" class="w-24 h-auto rounded-lg shadow-lg object-contain" />
            <img src="/assets/buttons/card.webp" alt="Cards preview" class="w-24 h-auto rounded-lg shadow-lg object-contain hidden sm:block" />
            <img src="/assets/buttons/colection.webp" alt="Collection preview" class="w-24 h-auto rounded-lg shadow-lg object-contain" />
          </div>
          <span class="text-gray-300 font-spectral mt-1 bg-black/60 px-4 py-1 rounded-full text-sm relative z-10 text-center">
            {lang === 'es' ? 'Academia Mágica: Quiz y Cromos - Google Play' : 'Magic Academy: Quiz & Cards - Google Play'}
          </span>
        </div>
      </a>

      <!-- YOUTUBE LINK -->
      <a 
        href="https://www.youtube.com/@elpensadero_HP" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative flex items-center justify-between p-4 rounded-xl hover:scale-105 transition-transform duration-300 shadow-lg bg-black/40 border border-red-900/50 hover:border-red-600/80 hover:bg-black/60 backdrop-blur-sm overflow-hidden"
      >
        <div class="absolute inset-0 bg-[url('/assets/buttons/youtube.webp')] bg-cover bg-center opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <div class="flex items-center gap-4 z-10 relative">
          <div class="w-12 h-12 flex items-center justify-center bg-red-600 rounded-full shadow-[0_0_15px_rgba(220,38,38,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          </div>
          <div class="flex flex-col text-left">
            <span class="text-white font-cinzel font-bold text-lg">YouTube</span>
            <span class="text-red-300 text-sm font-spectral">@elpensadero_HP</span>
          </div>
        </div>
        <span class="text-white/50 z-10">→</span>
      </a>

      <!-- TIKTOK LINK -->
      <a 
        href="https://www.tiktok.com/@elpensadero_hp" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative flex items-center justify-between p-4 rounded-xl hover:scale-105 transition-transform duration-300 shadow-lg bg-black/40 border border-gray-700 hover:border-cyan-400/80 hover:bg-black/60 backdrop-blur-sm"
      >
        <div class="flex items-center gap-4 z-10">
          <div class="w-12 h-12 flex items-center justify-center bg-black rounded-full border border-gray-600 shadow-[0_0_15px_rgba(0,0,0,0.8)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.04.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </div>
          <div class="flex flex-col text-left">
            <span class="text-white font-cinzel font-bold text-lg">TikTok</span>
            <span class="text-cyan-300 text-sm font-spectral">@elpensadero_hp</span>
          </div>
        </div>
        <span class="text-white/50 z-10">→</span>
      </a>

      <!-- INSTAGRAM LINK -->
      <a 
        href="https://www.instagram.com/elpensadero_hp/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative flex items-center justify-between p-4 rounded-xl hover:scale-105 transition-transform duration-300 shadow-lg bg-black/40 border border-fuchsia-900/50 hover:border-fuchsia-500/80 hover:bg-black/60 backdrop-blur-sm"
      >
        <div class="flex items-center gap-4 z-10">
          <div class="w-12 h-12 flex items-center justify-center bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-600 rounded-full shadow-[0_0_15px_rgba(217,70,239,0.4)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <div class="flex flex-col text-left">
            <span class="text-white font-cinzel font-bold text-lg">Instagram</span>
            <span class="text-fuchsia-300 text-sm font-spectral">@elpensadero_hp</span>
          </div>
        </div>
        <span class="text-white/50 z-10">→</span>
      </a>

    </div>
  </main>
  <Footer />
</Layout>
