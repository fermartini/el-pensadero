---
import Home from "../../components/Home.astro";
import Shorts from "../../components/Shorts.astro";
import Layout from "../../layouts/Layout.astro";
import Blog from "../../components/Blog.astro";
import Footer from "../../components/Footer.astro";
import PromoSections from "../../components/PromoSections.astro";
import HogwartsSortingQuiz from "../../components/games/HogwartsSortingQuiz.tsx";
import PatronusGame from "../../components/games/PatronusGame.jsx";
import type { HomeContent } from "../../types.d.ts";
import type { GamesContent } from "../../types.d.ts";
// src/pages/[lang]/index.astro
export const prerender = true; // Para Static Site Generation (SSG)

// 1. Define los idiomas soportados
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } }, // Español
    { params: { lang: 'en' } }  // Inglés
  ];
}

// 2. Obtiene el parámetro de la URL
const { lang } = Astro.params;

// 3. Carga el contenido correspondiente
const { frontmatter: homeData } = await import(`../../content/${lang}/home.md`) as { frontmatter: HomeContent };
const { frontmatter: gamesData } = (await import(`../../content/${lang}/games.md`)) as {
  frontmatter: GamesContent;
};


const titleGame = gamesData.titleGame;
const descriptionGame = gamesData.descriptionGame;
const hat = gamesData.hat;
const start = gamesData.start;
const cualities = gamesData.cualities;
const fundador = gamesData.fundador;
const element = gamesData.element;
const yes = gamesData.yes;
const thinks = gamesData.thinks;
const again = gamesData.again;
const back = gamesData.back;
const ask = gamesData.ask;
const of = gamesData.of;
const interesting = gamesData.interesting;
const finishGame = gamesData.finishGame;

const title = homeData.title
const subTitle = homeData.subTitle
const labelledby = homeData.labelledby
const blog = homeData.blog
const games = homeData.games
const titleLayout = homeData.titleLayout
const descriptionLayout = homeData.descriptionLayout
const titleButton = homeData.titleButton
const readMore = homeData.readMore

---

<Layout
  title={titleLayout}
  description={descriptionLayout}
  url=`/${lang}`
>
  <Home 
    title={title} 
    subTitle={subTitle} 
    labelledby={labelledby} 
    lang={lang}
    cardLibrary={homeData.cardLibrary}
    cardGames={homeData.cardGames}
    cardSorting={homeData.cardSorting}
    cardBlogTitle={homeData.cardBlogTitle}
    cardBlogDesc={homeData.cardBlogDesc}
    cardGamesTitle={homeData.cardGamesTitle}
    cardGamesDesc={homeData.cardGamesDesc}
    cardSortingTitle={homeData.cardSortingTitle}
    cardSortingDesc={homeData.cardSortingDesc}
  />
  <Blog blog={blog} lang={lang} titleButton={titleButton} readMore={readMore}/>

  <!-- Patronus Game Section -->
  <section class="min-h-screen py-20 border-b border-[#B39D4E]/20" id="patronus-game">
    <h2 class="text-3xl md:text-6xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-6 drop-shadow-[0_0_15px_rgba(218,165,32,0.3)] px-4">
      {lang === 'en' ? 'Expecto Patronum: Dementor Defense' : 'Expecto Patronum: Defensa contra Dementores'}
    </h2>
    <p class="text-center text-gray-400 font-spectral mb-10 max-w-2xl mx-auto px-4">
      {lang === 'en' ? 'Defend the Pensieve from the Dementors in this fast-paced game!' : '¡Defiende el Pensadero de los Dementores en este mini-juego de reflejos!'}
    </p>
    <PatronusGame 
      client:visible 
      patronusTitle={gamesData.patronusTitle}
      patronusSubtitle={gamesData.patronusSubtitle}
      patronusStart={gamesData.patronusStart}
      patronusGameOver={gamesData.patronusGameOver}
      patronusScoreLabel={gamesData.patronusScoreLabel}
      patronusRetry={gamesData.patronusRetry}
      patronusVitalMagic={gamesData.patronusVitalMagic}
      patronusScoreHUD={gamesData.patronusScoreHUD}
    />
  </section>

  <section class="min-h-screen" id="featured-game">
  <h2
    class="text-3xl md:text-6xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-12 drop-shadow-[0_0_15px_rgba(218,165,32,0.3)] pt-20"
  >
  {games}
  </h2> <HogwartsSortingQuiz
      client:visible
      lang={lang}
      titleGame={titleGame}
      descriptionGame={descriptionGame}
      hat={hat}
      start={start}
      finishGame={finishGame}
      cualities={cualities}
      fundador={fundador}
      element={element}
      yes={yes}
      thinks={thinks}
      again={again}
      back={back}
      ask={ask}
      of={of}
      interesting={interesting}
    />
 </section>
  <PromoSections 
    gamePromoTitle={homeData.gamePromoTitle}
    gamePromoDesc={homeData.gamePromoDesc}
    ytPromoTitle={homeData.ytPromoTitle}
    ytPromoDesc={homeData.ytPromoDesc}
    downloadBtn={homeData.downloadBtn}
    visitYtBtn={homeData.visitYtBtn}
  />
  <Shorts lang={lang}/>

  <Footer />
</Layout>
