---
import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { BlogContent } from "../../../types.d.ts";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**/*.{jpeg,jpg,png,gif,webp}');

type Post = CollectionEntry<"posts">;

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const langDif = lang == 'es' ? 'en' : 'es'
const posts = await getCollection("posts", ({ data }) => data.lang === lang);
const { frontmatter } = await import(`../../../content/${lang}/blog.md`) as { frontmatter: BlogContent };

const title = frontmatter.title
const subTitle = frontmatter.subTitle
const x = frontmatter.x
const read = frontmatter.read
const readMore = frontmatter.readMore
const titleLayout = frontmatter.titleLayout
const descriptionLayout = frontmatter.descriptionLayout


// Filtrado con type guards
const importantTrue = posts
  .filter((post): post is Post => post.data.important === true)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const importantFalse = posts
  .filter((post): post is Post => !post.data.important)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Ordenamiento (manteniendo tu lógica)
let orderedItems: Post[] = [];
let i = 0, j = 0;

while (i < importantTrue.length || j < importantFalse.length) {
  if (i < importantTrue.length) {
    orderedItems.push(importantTrue[i]);
    i++;
  }

  let added = 0;
  while (added < 4 && j < importantFalse.length) {
    orderedItems.push(importantFalse[j]);
    j++;
    added++;
  }
}
orderedItems = orderedItems.reverse();
---

<Layout
  title={titleLayout}
  description={descriptionLayout}
  url={`/${lang}/blog`}
  canonical={`https://elpensaderohp.com/${lang}/blog/`}
  alternate={`https://elpensaderohp.com/${langDif}/blog/`}
>
  <main class="relative min-h-screen pt-32 pb-20 px-4 overflow-hidden">
    {/* Background effects */}
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-[radial-gradient(circle_at_center,rgba(179,157,78,0.15)_0%,transparent_70%)] pointer-events-none"></div>

    <div class="mx-auto max-w-7xl relative z-10">
      <div class="text-center mb-20 space-y-4">
        <h1 
          class="text-4xl md:text-7xl font-cinzel font-bold text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] drop-shadow-[0_0_15px_rgba(218,165,32,0.3)]"
          transition:name="blog-title"
        >
          {title}
        </h1>
        <p class="text-xl md:text-2xl font-spectral italic text-gray-400 max-w-2xl mx-auto">
          {subTitle}
        </p>
        <div class="w-24 h-1 bg-gradient-to-r from-transparent via-[#B39D4E] to-transparent mx-auto mt-6"></div>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-10">
        {
          orderedItems.map((post: any, index) => {
            const { data } = post;
            const {
              title,
              author,
              img,
              description,
              date,
              readtime,
              slug,
              category,
              important,
            } = data;
            
            // Resolve image path from /assets/img/ to /src/assets/img/
            const imagePath = img.replace('/assets/img/', '/src/assets/img/');
            const imageMetadata = images[imagePath];
            
            return (
              <li
                class:list={[
                  "group relative flex flex-col bg-slate-900/50 backdrop-blur-md rounded-[2.5rem] border border-white/10 hover:border-[#B39D4E]/40 transition-all duration-500 overflow-hidden shadow-2xl hover:shadow-[#B39D4E]/10",
                  {
                    "lg:col-span-2 md:flex-row": important,
                    "col-span-1": !important,
                  },
                ]}
                style={`animation-delay: ${index * 0.1}s`}
              >
                {/* Image Section */}
                <div class:list={[
                  "relative overflow-hidden aspect-video bg-slate-950",
                  { "md:w-1/2 lg:w-3/5": important, "w-full": !important }
                ]}>
                  <a href={`/${data.lang}/blog/${slug}`} class="block h-full relative overflow-hidden">
                    {imageMetadata ? (
                      <Image
                        src={imageMetadata()}
                        alt={title}
                        width={important ? 800 : 600}
                        height={important ? 450 : 337}
                        format="webp"
                        quality="mid"
                        loading={index < 2 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                        transition:name={`img-${slug}`}
                        class="relative w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      />
                    ) : (
                      <img
                        src={img}
                        alt={title}
                        class="relative w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      />
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-40"></div>
                  </a>
                  {important && (
                    <div className="absolute top-6 left-6 px-4 py-1 bg-[#B39D4E] text-black font-cinzel text-xs font-bold uppercase tracking-widest rounded-full shadow-lg">
                      Destacado
                    </div>
                  )}
                </div>

                {/* Content Section */}
                <div class:list={[
                  "p-8 md:p-10 flex flex-col flex-grow justify-between",
                  { "md:w-1/2 lg:w-2/5": important }
                ]}>
                  <div class="space-y-4">
                    <div class="flex items-center gap-4">
                      <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-cinzel text-[#B39D4E] uppercase tracking-wider">
                        {category}
                      </span>
                      <time datetime={date} class="text-xs font-spectral text-gray-400 italic">
                        {date}
                      </time>
                    </div>

                    <a href={`/${data.lang}/blog/${slug}`} class="block group/title">
                      <h2 class:list={[
                        "font-cinzel font-bold text-white group-hover/title:text-[#B39D4E] transition-colors duration-300 leading-tight",
                        { "text-3xl md:text-4xl": important, "text-2xl": !important }
                      ]}>
                        {title}
                      </h2>
                    </a>

                    <p class="text-gray-300 font-spectral text-lg line-clamp-3 leading-relaxed">
                      {description}
                    </p>
                  </div>

                  <div class="pt-8 mt-auto border-t border-white/10 flex items-center justify-between">
                    <div class="flex flex-col">
                      <span class="text-xs font-cinzel text-gray-400 uppercase tracking-tighter">{x} {author}</span>
                      <span class="text-xs font-spectral text-[#B39D4E] italic font-medium">{read}: {readtime}</span>
                    </div>

                    <a
                      href={`/${data.lang}/blog/${slug}`}
                      class="group/btn relative px-6 py-3 bg-white/10 hover:bg-[#B39D4E]/10 rounded-xl border border-white/10 hover:border-[#B39D4E]/40 transition-all duration-300 flex items-center gap-2"
                    >
                      <span class="font-cinzel text-sm text-white group-hover/btn:text-[#B39D4E] transition-colors">{readMore}</span>
                      <svg class="w-4 h-4 text-[#B39D4E] transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </main>
  <Footer />
</Layout>
