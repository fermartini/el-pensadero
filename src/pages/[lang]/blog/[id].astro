---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Button from "../../../components/Button.astro";
import Footer from "../../../components/Footer.astro";
import { YouTube } from "@astro-community/astro-embed-youtube";
import Blog from "../../../components/Blog.astro";
import HogwartsSortingQuiz from "../../../components/games/HogwartsSortingQuiz";
import ParticulasMagicas from "../../../components/ParticulasMagicas";
import type { HomeContent, GamesContent } from "../../../types.d.ts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post: any) => ({
    params: {
      lang: post.data.lang,
      id: post.data.slug,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const {
  title,
  img,
  description,
  slug,
  videoId,
  author,
  category,
  lang,
  durationVideo,
  slugLang,
} = data;

const langDif = lang == 'es'? 'en' : 'es'

const { frontmatter: homeData } = await import(`../../../content/${lang}/home.md`) as { frontmatter: HomeContent };
const { frontmatter: gameData } = await import(`../../../content/${lang}/games.md`) as { frontmatter: GamesContent };

const { Content } = await render(post);

const generateBlogJSONLD = (post: any) => {
  return JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: `https://elpensaderohp.com${post.data.img}`,
    url: `https://elpensaderohp.com/${lang}/blog/${post.data.slug}`,
    datePublished: post.data.dateFormatted,
    dateModified: post.data.dateFormatted,
    author: {
      "@type": "Person",
      name: post.data.author,
    },
    publisher: {
      "@type": "Organization",
      name: "El Pensadero",
      url: "https://elpensaderohp.com",
      logo: {
        "@type": "ImageObject",
        url: "https://elpensaderohp.com/favicon.png",
        width: "48",
        height: "48",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `https://elpensaderohp.com/${lang}/blog/${post.data.slug}`,
    },
    video: {
      "@type": "VideoObject",
      name: post.data.title,
      description: post.data.description,
      thumbnailUrl: `https://elpensaderohp.com${post.data.img}`,
      duration: durationVideo,
      uploadDate: post.data.dateFormatted,
      embedUrl: `https://www.youtube.com/embed/${post.data.videoId}`,
      contentUrl: `https://www.youtube.com/watch?v=${post.data.videoId}`,
    },
    articleSection: post.data.category,
  });
};
---

<Layout
  title={title}
  description={description}
  img={img}
  url={`/${lang}/blog/${slug}`}
  slugLang={slugLang}
  canonical={`https://elpensaderohp.com/${lang}/blog/${slug}`}
  alternate={`https://elpensaderohp.com/${langDif}/blog/${slugLang}`}
  type="article"
>
  <main class="relative pt-32 pb-20 overflow-hidden selection:bg-[#B39D4E]/30 selection:text-white">
    {/* Background Effects */}
    <div class="fixed inset-0 pointer-events-none opacity-40">
       <ParticulasMagicas client:load />
    </div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_center,rgba(179,157,78,0.12)_0%,transparent_70%)] pointer-events-none"></div>

    <article class="relative z-10 max-w-5xl mx-auto px-6">
      
      {/* Header Section */}
      <div class="text-center mb-16 space-y-8">
        <div class="flex flex-col items-center gap-4">
           <span class="px-6 py-1.5 bg-[#B39D4E]/10 border border-[#B39D4E]/30 rounded-full text-[10px] font-cinzel text-[#B39D4E] uppercase tracking-[0.4em] shadow-[0_0_15px_rgba(179,157,78,0.2)]">
             {category}
           </span>
           <div class="flex items-center gap-3 text-gray-500 font-spectral italic text-sm">
             <span class="w-8 h-[1px] bg-white/10"></span>
             <span>escrito por <span class="text-gray-300 font-medium">{author}</span></span>
             <span class="w-8 h-[1px] bg-white/10"></span>
           </div>
        </div>
        <h1 class="text-3xl md:text-6xl font-cinzel font-bold text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] via-[#B39D4E] to-[#8C7A3A] drop-shadow-[0_0_30px_rgba(218,165,32,0.3)] leading-tight w-full">
          {title}
        </h1>
        <p class="text-lg md:text-xl font-spectral italic text-gray-400 max-w-2xl mx-auto leading-relaxed border-l-2 border-[#B39D4E]/20 pl-6 py-2">
          {description}
        </p>
      </div>

      {/* Video Section (Full Width and Centered) */}
      <div class="relative group mb-20 w-full flex justify-center">
        <div class="relative w-full">
          <div class="absolute -inset-4 bg-gradient-to-r from-[#B39D4E]/20 via-transparent to-[#B39D4E]/20 blur-3xl opacity-30 group-hover:opacity-60 transition duration-1000"></div>
          <div class="relative bg-slate-900 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden border-2 border-white/5 shadow-[0_0_80px_rgba(0,0,0,0.6)] w-full">
            <YouTube
              id={videoId}
              poster={img}
              class="w-full max-w-full aspect-video object-cover transition-transform duration-1000 group-hover:scale-[1.01]"
              playlabel={`Reproducir: ${title}`}
              transition:name={`img-${slug}`}
            />
          </div>
        </div>
      </div>

      <script type="application/ld+json" set:html={generateBlogJSONLD(post)} />

      {/* Content Section */}
      <div class="prose prose-invert prose-2xl max-w-none font-spectral leading-[1.8] text-gray-300 
        prose-p:mb-10
        prose-headings:font-cinzel prose-headings:text-transparent prose-headings:bg-clip-text prose-headings:bg-gradient-to-r prose-headings:from-[#FFF8D6] prose-headings:to-[#B39D4E] prose-headings:drop-shadow-md
        prose-a:text-[#B39D4E] prose-a:no-underline prose-a:border-b prose-a:border-[#B39D4E]/30 hover:prose-a:border-[#B39D4E] hover:prose-a:text-white transition-all
        prose-strong:text-[#FFF8D6] prose-strong:font-bold
        prose-img:rounded-[2rem] prose-img:border prose-img:border-white/10 prose-img:shadow-2xl
        custom-content mb-24">
        <Content />
      </div>

      <style is:global>
        .custom-content p:first-of-type::first-letter {
          float: left;
          font-family: 'Cinzel', serif;
          font-size: 5.5rem;
          line-height: 0.75;
          font-weight: bold;
          margin-top: 0.6rem;
          margin-right: 0.8rem;
          color: #B39D4E;
          text-shadow: 0 0 20px rgba(179, 157, 78, 0.4);
          background: linear-gradient(to bottom, #FFF8D6, #B39D4E);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
        }
      </style>

      {/* Action Buttons */}
      <div class="flex flex-col items-center gap-10 py-10 border-t border-white/5">
        <Button 
          title={lang == "es"? "🪄 VOLVER AL BLOG" : "🪄 BACK TO BLOG"} 
          slug={`/${lang}/blog`} 
          aria={lang == "es"? "Volver al blog" : "Back to Blog"}  
        />

        {/* Modern Social Share */}
        <div class="w-full max-w-2xl">
          <p class="text-center font-cinzel text-xs text-[#B39D4E] uppercase tracking-[0.3em] mb-6">Compartir Conocimiento</p>
          <div class="flex flex-wrap justify-center gap-4">
            {[
              { name: 'Twitter', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z', color: 'hover:bg-[#1DA1F2]/20', href: `https://twitter.com/intent/tweet?url=https://elpensaderohp.com/${lang}/blog/${slug}&text=${title}` },
              { name: 'WhatsApp', icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488', color: 'hover:bg-[#25D366]/20', href: `https://api.whatsapp.com/send?text=${title} https://elpensaderohp.com/${lang}/blog/${slug}` },
            ].map(social => (
              <a 
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`p-4 rounded-2xl bg-white/5 border border-white/10 ${social.color} hover:border-[#B39D4E]/40 transition-all duration-300 text-white`}
                title={social.name}
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d={social.icon}></path>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </article>

    {/* Footer Interaction Section */}
    <section class="max-w-7xl mx-auto px-4 mt-20">
      <h2 class="text-3xl md:text-6xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-12 drop-shadow-lg pt-20">
        {gameData.games}
      </h2>
      <HogwartsSortingQuiz
        client:load
        lang={lang}
        titleGame={gameData.titleGame} 
        descriptionGame={gameData.descriptionGame} 
        hat={gameData.hat}
        start={gameData.start}
        finishGame={gameData.finishGame}
        cualities={gameData.cualities}
        fundador={gameData.fundador}
        element={gameData.element}
        yes={gameData.yes}
        thinks={gameData.thinks}
        again={gameData.again}
        back={gameData.back}
        ask={gameData.ask}
        of={gameData.of}
        interesting={gameData.interesting}
      />
    </section>  

    <div class="mt-20">
      <Blog 
        blog={lang == "es"? "Del Pensadero para vos" : "The Pensieve’s Pick for You"} 
        lang={lang} 
        titleButton={lang == "es"? "Ver Todo" : "View All"} 
        readMore={lang == "es"? "Leer Más" : "Read More"}
      />
    </div>
  </main>
  <Footer />
</Layout>
