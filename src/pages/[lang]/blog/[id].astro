---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Button from "../../../components/Button.astro";
import Footer from "../../../components/Footer.astro";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { Image, getImage } from "astro:assets";
import Blog from "../../../components/Blog.astro";
import HogwartsSortingQuiz from "../../../components/games/HogwartsSortingQuiz.tsx";
import ParticulasMagicas from "../../../components/ParticulasMagicas";
import type { HomeContent, GamesContent } from "../../../types.d.ts";

// Import assets
import academyIcon from "../../../assets/img/icons/academy_game_card_v2.png";
import ytBanner from "../../../assets/img/icons/youtube_details_banner.png";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**/*.{jpeg,jpg,png,gif,webp}');

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post: any) => ({
    params: {
      lang: post.data.lang,
      id: post.data.slug,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const {
  title,
  img,
  description,
  slug,
  videoId,
  author,
  category,
  lang,
  durationVideo,
  slugLang,
} = data;

const langDif = lang == 'es'? 'en' : 'es'

// Resolve post image metadata and get optimized URL for the poster
const imagePath = img.replace('/assets/img/', '/src/assets/img/');
const postImageMetadata = images[imagePath];
const imageModule = postImageMetadata ? await postImageMetadata() : null;
const optimizedPoster = imageModule 
  ? await getImage({ src: imageModule.default, width: 1280, height: 720, format: 'webp' })
  : { src: img };

const { frontmatter: homeData } = await import(`../../../content/${lang}/home.md`) as { frontmatter: HomeContent };
const { frontmatter: gameData } = await import(`../../../content/${lang}/games.md`) as { frontmatter: GamesContent };

const { Content } = await render(post);

const generateBlogJSONLD = (post: any) => {
  return JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: `https://elpensaderohp.com${post.data.img}`,
    url: `https://elpensaderohp.com/${lang}/blog/${post.data.slug}`,
    datePublished: post.data.dateFormatted,
    dateModified: post.data.dateFormatted,
    author: {
      "@type": "Person",
      name: post.data.author,
    },
    publisher: {
      "@type": "Organization",
      name: "El Pensadero",
      url: "https://elpensaderohp.com",
      logo: {
        "@type": "ImageObject",
        url: "https://elpensaderohp.com/favicon.png",
        width: "48",
        height: "48",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `https://elpensaderohp.com/${lang}/blog/${post.data.slug}`,
    },
    video: {
      "@type": "VideoObject",
      name: post.data.title,
      description: post.data.description,
      thumbnailUrl: `https://elpensaderohp.com${post.data.img}`,
      duration: durationVideo,
      uploadDate: post.data.dateFormatted,
      embedUrl: `https://www.youtube.com/embed/${post.data.videoId}`,
      contentUrl: `https://www.youtube.com/watch?v=${post.data.videoId}`,
    },
    articleSection: post.data.category,
  });
};
---

<Layout
  title={title}
  description={description}
  img={img}
  url={`/${lang}/blog/${slug}`}
  slugLang={slugLang}
  canonical={`https://elpensaderohp.com/${lang}/blog/${slug}`}
  alternate={`https://elpensaderohp.com/${langDif}/blog/${slugLang}`}
  type="article"
>
  <main class="relative pt-32 pb-20 overflow-hidden selection:bg-[#B39D4E]/30 selection:text-white">
    {/* Background Effects */}
    <div class="fixed inset-0 pointer-events-none opacity-40">
       <ParticulasMagicas client:idle />
    </div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_center,rgba(179,157,78,0.12)_0%,transparent_70%)] pointer-events-none"></div>

    <article class="relative z-10 max-w-5xl mx-auto px-6">
      
      {/* Header Section */}
      <div class="text-center mb-16 space-y-8">
        <div class="flex flex-col items-center gap-4">
           <span class="px-6 py-1.5 bg-[#B39D4E]/10 border border-[#B39D4E]/30 rounded-full text-[10px] font-cinzel text-[#B39D4E] uppercase tracking-[0.4em] shadow-[0_0_15px_rgba(179,157,78,0.2)]">
             {category}
           </span>
           <div class="flex items-center gap-3 text-gray-500 font-spectral italic text-sm">
             <span class="w-8 h-[1px] bg-white/10"></span>
             <span>escrito por <span class="text-gray-300 font-medium">{author}</span></span>
             <span class="w-8 h-[1px] bg-white/10"></span>
           </div>
        </div>
        <h1 class="text-3xl md:text-6xl font-cinzel font-bold text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] via-[#B39D4E] to-[#8C7A3A] drop-shadow-[0_0_30px_rgba(218,165,32,0.3)] leading-tight w-full">
          {title}
        </h1>
        <p class="text-lg md:text-xl font-spectral italic text-gray-300 max-w-2xl mx-auto leading-relaxed border-l-2 border-[#B39D4E]/20 pl-6 py-2">
          {description}
        </p>
      </div>

      {/* Video Section (Full Width and Centered) */}
      <div class="relative group mb-20 w-full flex justify-center">
        <div class="relative w-full">
          <div class="absolute -inset-4 bg-gradient-to-r from-[#B39D4E]/20 via-transparent to-[#B39D4E]/20 blur-3xl opacity-30 group-hover:opacity-60 transition duration-1000"></div>
          <div 
            class="relative bg-slate-900 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden border-2 border-white/5 shadow-[0_0_80px_rgba(0,0,0,0.6)] w-full aspect-video"
            transition:name={`img-${slug}`}
          >
            <YouTube
              id={videoId}
              poster={optimizedPoster.src}
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.01]"
              playlabel={`Reproducir: ${title}`}
            />
          </div>
        </div>
      </div>

      <script type="application/ld+json" set:html={generateBlogJSONLD(post)} />

      {/* Content Section */}
      <div class="prose mb- prose-invert prose-2xl max-w-none font-spectral leading-[1.8] text-gray-300 
        prose-p:mb-10
        prose-headings:font-cinzel prose-headings:text-transparent prose-headings:bg-clip-text prose-headings:bg-gradient-to-r prose-headings:from-[#FFF8D6] prose-headings:to-[#B39D4E] prose-headings:drop-shadow-md
        prose-a:text-[#B39D4E] prose-a:no-underline prose-a:border-b prose-a:border-[#B39D4E]/30 hover:prose-a:border-[#B39D4E] hover:prose-a:text-white transition-all
        prose-strong:text-[#FFF8D6] prose-strong:font-bold
        prose-img:rounded-[2rem] prose-img:border prose-img:border-white/10 prose-img:shadow-2xl
        custom-content mb-24">
        <Content />

        {/* Footer YouTube Promotion (Matched Style) */}
        <div class="not-prose w-full mt-20 p-8 md:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900 via-slate-950 to-black border border-red-500/30 shadow-2xl relative overflow-hidden group">
          <div class="absolute -top-24 -right-24 w-96 h-96 bg-red-600/5 rounded-full blur-[100px] group-hover:bg-red-600/10 transition-all duration-1000"></div>
          <div class="relative z-10 flex flex-col lg:flex-row items-center gap-10">
            <div class="w-full lg:w-1/2">
              <div class="relative rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl transform transition-transform duration-700 group-hover:scale-[1.02]">
                <Image 
                  src={ytBanner} 
                  alt="YouTube Challenges" 
                  width={600}
                  height={337}
                  format="webp"
                  quality="mid"
                  class="w-full h-full object-cover" 
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              </div>
            </div>
            <div class="w-full lg:w-1/2 text-center lg:text-left space-y-6">
              <h3 class="text-3xl md:text-4xl font-cinzel font-bold text-white drop-shadow-lg">
                {homeData.footerYtPromoTitle}
              </h3>
              <p class="text-gray-300 font-spectral text-lg italic leading-relaxed">
                {homeData.footerYtPromoDesc}
              </p>
              <div class="pt-4">
                <a 
                  href="https://www.youtube.com/@elpensadero_HP" 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-10 py-4 bg-red-600 text-white font-cinzel font-bold text-sm rounded-full hover:bg-red-700 hover:scale-105 hover:shadow-[0_0_30px_rgba(239,68,68,0.4)] transition-all duration-300"
                >
                  {homeData.visitYtBtn}
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style is:global>
        .custom-content p:first-of-type::first-letter {
          float: left;
          font-family: 'Cinzel', serif;
          font-size: 5.5rem;
          line-height: 0.75;
          font-weight: bold;
          margin-top: 0.6rem;
          margin-right: 0.8rem;
          color: #B39D4E;
          text-shadow: 0 0 20px rgba(179, 157, 78, 0.4);
          background: linear-gradient(to bottom, #FFF8D6, #B39D4E);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
        }
      </style>

      {/* Action Buttons */}
      <div class="flex flex-col items-center gap-10 py-10 border-t border-white/5">
        <Button 
          title={lang == "es"? "🪄 VOLVER AL BLOG" : "🪄 BACK TO BLOG"} 
          slug={`/${lang}/blog`} 
          aria={lang == "es"? "Volver al blog" : "Back to Blog"}  
        />

        {/* Modern Social Share */}
        <div class="w-full max-w-2xl">
          <p class="text-center font-cinzel text-xs text-[#B39D4E] uppercase tracking-[0.3em] mb-6">Compartir Conocimiento</p>
          <div class="flex flex-wrap justify-center gap-4">
            {[
              { name: 'Twitter', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z', color: 'hover:bg-[#1DA1F2]/20', href: `https://twitter.com/intent/tweet?url=https://elpensaderohp.com/${lang}/blog/${slug}&text=${title}` },
              { name: 'WhatsApp', icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488', color: 'hover:bg-[#25D366]/20', href: `https://api.whatsapp.com/send?text=${title} https://elpensaderohp.com/${lang}/blog/${slug}` },
            ].map(social => (
              <a 
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`p-4 rounded-2xl bg-white/5 border border-white/10 ${social.color} hover:border-[#B39D4E]/40 transition-all duration-300 text-white`}
                title={social.name}
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d={social.icon}></path>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </article>

    {/* Floating Download Button (Strategic) */}
    <a 
      href="https://play.google.com/store/apps/details?id=com.khalldragon.elpensadero"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-[100] group flex items-center bg-black/80 backdrop-blur-md border border-[#B39D4E]/40 rounded-full md:bg-transparent md:border-0 md:backdrop-blur-none md:shadow-none p-1 md:p-0 shadow-2xl"
      aria-label={lang == "es" ? "Descargar Academia Mágica" : "Download Magic Academy"}
    >
      <div class="px-4 py-2 md:px-5 md:py-2.5 bg-transparent md:bg-black/80 md:backdrop-blur-md md:border md:border-[#B39D4E]/40 rounded-full md:rounded-2xl text-[#B39D4E] font-cinzel text-[10px] tracking-widest uppercase md:transform md:transition-all md:duration-500 md:group-hover:bg-[#B39D4E] md:group-hover:!text-black md:mr-4">
        {homeData.downloadStickyText}
      </div>
      <div class="relative">
        <div class="absolute -inset-2 bg-[#B39D4E]/40 rounded-full blur-lg opacity-40 group-hover:opacity-100 transition-opacity duration-500 animate-pulse hidden md:block"></div>
        <div class="relative flex items-center justify-center w-12 h-12 md:w-20 md:h-20 bg-gradient-to-br from-[#B39D4E] to-[#8C7A3A] rounded-full shadow-[0_0_40px_rgba(0,0,0,0.5)] border-2 border-[#FFF8D6]/50 overflow-hidden transform transition-all duration-500 md:group-hover:scale-110 md:group-hover:-translate-y-2">
          <Image 
            src={academyIcon} 
            width={80}
            height={80}
            format="webp"
            quality="mid"
            class="w-full h-full object-cover" 
            alt="App Icon" 
          />
        </div>
      </div>
    </a>

    {/* Mid-Post Promotion Template (Moved by script) */}
    <div id="mid-post-promo-template" class="hidden" aria-hidden="true">
      <div class="not-prose my-16 p-8 md:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900 via-slate-950 to-black border border-[#B39D4E]/30 shadow-2xl relative overflow-hidden group min-h-[200px]">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#B39D4E]/5 rounded-full blur-3xl -mr-32 -mt-32"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-8">
          <div class="w-24 h-24 md:w-32 md:h-32 flex-shrink-0">
             <Image 
               src={academyIcon} 
               width={128}
               height={128}
               format="webp"
               quality="mid"
               class="w-full h-full object-contain rounded-3xl shadow-2xl border border-[#B39D4E]/20" 
               alt="Icon" 
             />
          </div>
          <div class="flex-grow text-center md:text-left space-y-4">
            <h3 class="text-2xl md:text-3xl font-cinzel font-bold text-[#FFF8D6]">{homeData.midPostPromoTitle}</h3>
            <p class="text-gray-300 font-spectral text-base md:text-lg italic leading-relaxed">
              {homeData.midPostPromoDesc}
            </p>
            <div class="pt-2">
              <a 
                href="https://play.google.com/store/apps/details?id=com.khalldragon.elpensadero" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center px-6 py-3 bg-[#B39D4E] text-black font-cinzel font-bold text-xs rounded-full hover:scale-105 hover:shadow-[0_0_20px_#B39D4E/40] transition-all !text-black"
              >
                {homeData.downloadBtn}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const content = document.querySelector('.custom-content');
        const template = document.querySelector('#mid-post-promo-template');
        
        if (content && template) {
          const promo = template.firstElementChild;
          if (!promo) return;
          
          const sections = content.querySelectorAll('section');
          
          // Use requestAnimationFrame to avoid blocking and minimize perceived shift
          requestAnimationFrame(() => {
            if (sections.length >= 2) {
              sections[1].insertAdjacentElement('afterend', promo);
            } else {
              content.appendChild(promo);
            }
          });
        }
      });
    </script>

    {/* Footer Interaction Section */}
    <section class="max-w-7xl mx-auto px-4 mt-20">
      <h2 class="text-3xl md:text-6xl font-cinzel text-center text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] to-[#B39D4E] mb-12 drop-shadow-lg pt-20">
        {gameData.games}
      </h2>
      <HogwartsSortingQuiz
        client:visible
        lang={lang}
        titleGame={gameData.titleGame} 
        descriptionGame={gameData.descriptionGame} 
        hat={gameData.hat}
        start={gameData.start}
        finishGame={gameData.finishGame}
        cualities={gameData.cualities}
        fundador={gameData.fundador}
        element={gameData.element}
        yes={gameData.yes}
        thinks={gameData.thinks}
        again={gameData.again}
        back={gameData.back}
        ask={gameData.ask}
        of={gameData.of}
        interesting={gameData.interesting}
      />
    </section>  

    <div class="mt-20">
      <Blog 
        blog={lang == "es"? "Del Pensadero para vos" : "The Pensieve’s Pick for You"} 
        lang={lang} 
        titleButton={lang == "es"? "Ver Todo" : "View All"} 
        readMore={lang == "es"? "Leer Más" : "Read More"}
      />
    </div>
  </main>
  <Footer />
</Layout>
