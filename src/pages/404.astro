---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import errorImg from "../assets/img/404-magic.png";

const title = "404 - ¡Hechizo Fallido! | El Pensadero";
const description = "Parece que has usado polvos flú caducados. Esta página no existe en nuestro universo mágico.";
---

<Layout title={title} description={description} url="/404">
  <main class="relative h-[100dvh] w-full flex items-center justify-center overflow-hidden selection:bg-[#B39D4E]/30">
    <!-- Background Magic -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#B39D4E]/10 rounded-full blur-[120px] animate-pulse"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center flex flex-col items-center justify-center h-full py-10">
      <!-- Image Container -->
      <div class="relative inline-block mb-6 group shrink-0">
        <div class="absolute -inset-4 bg-gradient-to-r from-[#B39D4E]/30 to-purple-600/30 blur-2xl opacity-50 group-hover:opacity-100 transition duration-1000"></div>
        <div class="relative rounded-[2.5rem] md:rounded-[3.rem] overflow-hidden border-2 border-white/10 shadow-2xl transform transition-transform duration-700 group-hover:scale-[1.02] group-hover:rotate-1 max-w-[280px] md:max-w-md mx-auto">
          <Image 
            src={errorImg} 
            alt="Mago confundido" 
            width={600} 
            height={600} 
            class="w-full h-auto"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <!-- Floating Elements -->
        <div class="absolute -top-6 -right-6 text-3xl md:text-4xl animate-bounce delay-100">🫧</div>
        <div class="absolute -bottom-6 -left-6 text-3xl md:text-4xl animate-bounce delay-500">🫧</div>
      </div>

      <!-- Text Content -->
      <div class="space-y-4 md:space-y-6 shrink">
        <h1 class="font-cinzel text-6xl md:text-8xl lg:text-9xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-[#FFF8D6] via-[#B39D4E] to-[#8C7A3A] drop-shadow-[0_0_30px_rgba(179,157,78,0.4)] leading-none">
          404
        </h1>
        
        <div class="space-y-2 md:space-y-4">
          <h2 class="font-cinzel text-xl md:text-3xl text-white font-bold tracking-tight">
            ¡POR LAS BARBAS DE MERLÍN!
          </h2>
          <p class="font-spectral text-lg md:text-xl italic text-gray-300 max-w-2xl mx-auto leading-relaxed">
            "Parece que has usado polvos flú caducados. Esta página ha desaparecido más rápido que un <span class="text-[#B39D4E] font-bold">Snitch Dorada</span>."
          </p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-8 pt-6">
          <a 
            href="/es" 
            class="group relative px-10 py-4 bg-[#B39D4E] text-black font-cinzel font-bold text-sm rounded-full transition-all hover:scale-110 hover:shadow-[0_0_30px_rgba(179,157,78,0.5)]"
          >
            🪄 LANZAR HECHIZO DE RETORNO
          </a>
          <a 
            href="/es/blog" 
            class="font-cinzel text-[#B39D4E] text-sm tracking-widest hover:text-white transition-colors border-b border-[#B39D4E]/30 hover:border-white pb-1"
          >
            EXPLORAR LA BIBLIOTECA
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
